{
  "name": "custom-bluefin-dc",
  "image": "quay.io/podman/stable:latest",
  "service": "custom-bluefin-dc",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "upgradePackages": true,
      "installOhMyZsh": false,
      "installOhMyZshConfig": false,
      "username": "none"
    }
  },
  "containerEnv": {
    "LANG": "en_US.UTF-8",
    "LANGUAGE": "en_US:en",
    "CONTAINER_HOST": "unix:///var/run/podman.sock"
  },
  "runArgs": [
    "--cap-add=CAP_MKNOD",
    "--cap-add=NET_ADMIN",
    "--cap-add=SYS_ADMIN",
    "--cap-add=SYS_RESOURCE",
    "--device",
    "/dev/fuse",
    "--security-opt",
    "seccomp=unconfined",
    "--security-opt",
    "label=disable",
    "--security-opt",
    "apparmor=unconfined",
    "--userns=host",
    "-v",
    "/run/user/1000/podman/podman.sock:/var/run/podman.sock:Z",
    "--hostname=ad-scripts-dc"
  ],
  "remoteUser": "root",
  "containerUser": "root"
}
